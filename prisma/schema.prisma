// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Ticket status
// 01 for open
// 02 for confirm
// 03 for fail
// 04 for pending

// Order status
// 01 for open
// 02 for confirm
// 03 for fail

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ROOTADMIN
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  fullname      String   
  password      String
  role          Role
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticket        Ticket[]
  card          Card[]
  account       Account[]
  lottery       Lottery[]
  result        Result[]
}

model Ticket {
  id            String   @id @default(uuid())
  alphabet      String
  number        String
  time          String
  date          String
  annoucedate   String
  status        String
  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userid        String
  user          User @relation(fields: [userid], references: [id])

  payment       Payment[] @relation("TicketPayments")
}

model Card {
  id            String   @id @default(uuid())
  icon          String
  name          String
  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userid        String
  user          User @relation(fields: [userid], references: [id])

  account       Account[]
}

model Account {
  id            String   @id @default(uuid())
  name          String
  phone         String
  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userid        String
  user          User @relation(fields: [userid], references: [id])
  cardid        String
  card          Card @relation(fields: [cardid], references: [id])
}

model Lottery {
  id            String   @id @default(uuid())
  logo          String
  title         String
  desc          String
  org           Json[]
  terms         String
  price         String
  isSelect      Boolean
  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userid        String
  user          User @relation(fields: [userid], references: [id])

  order         Order[]
}

model Payment {
  id            String   @id @default(uuid())
  name          String
  address       String
  phone         String
  purchasedate  DateTime @default(now())
  screenshot    String

  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticket        Ticket[] @relation("TicketPayments")
  order         Order[]
}

model Order {
  id            String   @id @default(uuid())
  invoiceno     String   @unique
  qrcode        String
  status        String

  paymentid     String
  payment       Payment @relation(fields: [paymentid], references: [id])
  lotteryid     String
  lottery       Lottery @relation(fields: [lotteryid], references: [id])

  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Result {
  id            String   @id @default(uuid())
  date          String
  image         String

  t1            String?
  t2            String?
  t3            String?
  t4            String?
  t5            String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userid        String
  user          User @relation(fields: [userid], references: [id])
}

model Image {
  id        String   @id @default(uuid())
  url       String
  key       String
  createdAt DateTime @default(now())
}

